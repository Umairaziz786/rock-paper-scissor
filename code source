#include <iostream>
#include <cstdlib>
#include <ctime>

using namespace std;

class RockPaperScissors {
private:
    int userChoice, computerChoice;
    int userScore, computerScore;
    char playAgain;

public:
    RockPaperScissors() {
        userScore = 0;
        computerScore = 0;
    }

    void showMenu() {
        cout << "\n=================================\n";
        cout << "     ROCK PAPER SCISSORS GAME\n";
        cout << "=================================\n";
        cout << "1. Rock\n";
        cout << "2. Paper\n";
        cout << "3. Scissors\n";
        cout << "Enter your choice (1-3): ";
    }

    string getChoiceName(int choice) {
        if (choice == 1)
            return "Rock";
        else if (choice == 2)
            return "Paper";
        else
            return "Scissors";
    }

    void playGame() {
        srand(time(0));

        do {
            showMenu();
            cin >> userChoice;

            while (userChoice < 1 || userChoice > 3) {
                cout << "Invalid choice! Please enter again (1-3): ";
                cin >> userChoice;
            }

            computerChoice = rand() % 3 + 1;

            cout << "\nYou chose: " << getChoiceName(userChoice) << endl;
            cout << "Computer chose: " << getChoiceName(computerChoice) << endl;

            if (userChoice == computerChoice) {
                cout << "Result: Match Draw!\n";
            }
            else if ((userChoice == 1 && computerChoice == 3) ||
                     (userChoice == 2 && computerChoice == 1) ||
                     (userChoice == 3 && computerChoice == 2)) {

                cout << "Result: You Win!\n";
                userScore++;
            }
            else {
                cout << "Result: Computer Wins!\n";
                computerScore++;
            }

            cout << "\nCurrent Score\n";
            cout << "You: " << userScore << endl;
            cout << "Computer: " << computerScore << endl;

            cout << "\nDo you want to play again? (y/n): ";
            cin >> playAgain;

        } while (playAgain == 'y' || playAgain == 'Y');

        cout << "\n=================================\n";
        cout << "         FINAL SCORE\n";
        cout << "=================================\n";
        cout << "You: " << userScore << endl;
        cout << "Computer: " << computerScore << endl;

        if (userScore > computerScore)
            cout << "Congratulations! You are the overall winner!\n";
        else if (computerScore > userScore)
            cout << "Computer is the overall winner!\n";
        else
            cout << "The game ended in a draw!\n";
    }
};

int main() {
    RockPaperScissors game;
    game.playGame();

    return 0;
}
